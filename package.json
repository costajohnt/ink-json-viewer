{
  "name": "ink-json-viewer",
  "version": "0.1.0",
  "description": "Interactive, collapsible JSON tree viewer component for Ink",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ink": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "^6.0.0",
    "@types/react": "^18.0.0",
    "delay": "^7.0.0",
    "ink": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "ink",
    "cli",
    "json",
    "viewer",
    "tree",
    "terminal",
    "react",
    "tui",
    "inspector"
  ],
  "author": "John Costa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/costajohnt/ink-json-viewer"
  },
  "homepage": "https://github.com/costajohnt/ink-json-viewer#readme",
  "bugs": "https://github.com/costajohnt/ink-json-viewer/issues",
  "engines": {
    "node": ">=20"
  }
}
